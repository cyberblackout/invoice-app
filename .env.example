# ===========================================
# DATABASE - Supabase Configuration
# ===========================================
# Get these from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# PAYMENT GATEWAYS - Ghana
# ===========================================
# Paystack - https://paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-public-key
PAYSTACK_SECRET_KEY=sk_test_your-secret-key

# Hubtel - https://hubtel.com
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your-merchant-number
HUBTEL_MERCHANT_API_KEY=your-merchant-api-key

# ===========================================
# BUSINESS SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
BUSINESS_NAME=Your Business Name
BUSINESS_TIN=your-tin-number

# ===========================================
# NOTIFICATIONS (Optional)
# ===========================================
# WhatsApp Business API (for notifications)
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER=your-whatsapp-number

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=your-email@example.com