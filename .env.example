# ===========================================
# CYBER INVOICEFLOW - Configuration
# ===========================================
# IMPORTANT: Copy this file to .env before running
# cp .env.example .env
# Then fill in your values below
#
# Services:
# - Database: https://supabase.com
# - Payments: https://paystack.com | https://hubtel.com

# ===========================================
# DATABASE - Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# PAYMENT GATEWAYS - Ghana
# ===========================================
# Paystack - https://paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Hubtel - https://hubtel.com
HUBTEL_MERCHANT_ACCOUNT_NUMBER=
HUBTEL_MERCHANT_API_KEY=

# ===========================================
# BUSINESS SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL=
BUSINESS_NAME=
BUSINESS_TIN=

# ===========================================
# NOTIFICATIONS (Optional)
# ===========================================
# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER=

# Email - SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=